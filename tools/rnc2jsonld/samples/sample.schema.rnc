namespace docset = "http://dgml.io/acme-corp/master-services-agreements#"

ContractLevelTag = IndemnificationClause | PaymentTerms | BilledCharges
ClauseItemTag    = LiabilityCap | EffectiveDate | VendorName
                 | IndemnifyingParty | IndemnifiedParty
                 | InvoiceCycle | LatePaymentPenalty
TableRowTag      = BilledCharge
TableCellTag     = ProductName | UnitPrice | OrderedQuantity
InlineTag        = SignatoryName

AnyTag = ContractLevelTag | ClauseItemTag | TableRowTag | TableCellTag | InlineTag

## Indemnification clause section
IndemnificationClause =
  element docset:IndemnificationClause {
    (text | AnyTag)*
  }

## Payment terms section
PaymentTerms =
  element docset:PaymentTerms {
    (text | AnyTag)*
  }

## Table of billed charges
BilledCharges =
  element docset:BilledCharges {
    (text | AnyTag)*
  }

## Agreed maximum liability exposure under the contract
## Example: $500,000
LiabilityCap =
  element docset:LiabilityCap {
    (text | AnyTag)*
  }

## Effective date of the contract
## Example: January 1, 2024
EffectiveDate =
  element docset:EffectiveDate {
    (text | AnyTag)*
  }

## Legal name of the vendor party
## Example: MagicSoft, Inc.
VendorName =
  element docset:VendorName {
    (text | AnyTag)*
  }

## Party responsible for providing indemnification
## Example: Vendor
IndemnifyingParty =
  element docset:IndemnifyingParty {
    (text | AnyTag)*
  }

## Party receiving indemnification protection
## Example: Client
IndemnifiedParty =
  element docset:IndemnifiedParty {
    (text | AnyTag)*
  }

## Payment cycle for invoices
## Example: Net 30
InvoiceCycle =
  element docset:InvoiceCycle {
    (text | AnyTag)*
  }

## Penalty rate applied to late payments
## Example: 1.5% per month
LatePaymentPenalty =
  element docset:LatePaymentPenalty {
    (text | AnyTag)*
  }

## A single billed charge line item
BilledCharge =
  element docset:BilledCharge {
    (text | AnyTag)*
  }

## Name of a billed product or service
## Example: Widget
ProductName =
  element docset:ProductName {
    (text | AnyTag)*
  }

## Unit price of a billed item
## Example: $9.95
UnitPrice =
  element docset:UnitPrice {
    (text | AnyTag)*
  }

## Quantity of units ordered
## Example: 3
OrderedQuantity =
  element docset:OrderedQuantity {
    (text | AnyTag)*
  }

## Name of a signatory
## Example: Jane Smith
SignatoryName =
  element docset:SignatoryName {
    (text | AnyTag)*
  }
